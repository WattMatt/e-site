{
  "name": "mobile",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:jest": "jest --passWithNoTests",
    "test:e2e": "detox test --configuration android.emu.debug",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:build:ios": "detox build --configuration ios.sim.debug"
  },
  "dependencies": {
    "@esite/db": "workspace:*",
    "@esite/shared": "workspace:*",
    "@hookform/resolvers": "^3.9.0",
    "@powersync/react-native": "^1.34.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.56.0",
    "date-fns": "^4.1.0",
    "expo": "^52.0.0",
    "expo-camera": "^15.0.0",
    "expo-file-system": "^17.0.0",
    "expo-image-picker": "^16.0.0",
    "expo-linking": "^7.0.0",
    "expo-notifications": "^0.29.0",
    "expo-router": "^4.0.0",
    "expo-secure-store": "^14.0.0",
    "expo-status-bar": "^2.0.0",
    "react": "18.3.1",
    "react-hook-form": "^7.53.0",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-reanimated": "^3.15.0",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^4.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@config-plugins/detox": "^9.0.0",
    "@testing-library/react-native": "^12.7.0",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.25.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-expo": "^52.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "detox": {
    "configurations": {
      "android.emu.debug": {
        "device": { "type": "android.emulator", "avdName": "Pixel_7_API_34" },
        "app": { "type": "android.apk", "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk" }
      },
      "ios.sim.debug": {
        "device": { "type": "ios.simulator", "device": { "type": "iPhone 15 Pro" } },
        "app": { "type": "ios.app", "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/esite.app" }
      }
    },
    "testRunner": {
      "args": { "$0": "jest", "config": "e2e/jest.config.js" },
      "jest": { "setupTimeout": 120000 }
    }
  }
}
